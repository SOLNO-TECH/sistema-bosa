PORT=4000
JWT_SECRET=your_secret_key_here
JWT_EXPIRES_IN=8h
NODE_ENV=development

# Web Push (pantalla de bloqueo / PWA). Opcional: si no se definen, se generan en data/vapid.json al arrancar.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@bosa.mx

# Transcripción de voz (whisper.cpp local — sin APIs de pago)
# Windows (instalado con tools/whisper):
# WHISPER_BIN=C:\Users\sistema-bosa\tools\whisper\Release\whisper-cli.exe
# WHISPER_MODEL=C:\Users\sistema-bosa\tools\whisper\models\ggml-small.bin
# FFMPEG_BIN=C:\Users\sistema-bosa\tools\ffmpeg\ffmpeg-8.1.1-essentials_build\bin\ffmpeg.exe
# Linux:
# WHISPER_BIN=/usr/local/bin/whisper-cli
# WHISPER_MODEL=/opt/whisper/models/ggml-small.bin
# WHISPER_LANGUAGE=es
# WHISPER_THREADS=4
# WHISPER_TIMEOUT_MS=600000
# VOICE_MAX_MB=80

# Comandos por voz: interpretación por reglas en el servidor (sin APIs de pago).
# VOICE_LEARN_SIMILARITY=0.78
# VOICE_LEARN_CRITICAL_SIMILARITY=0.88

# Refinamiento opcional con LLM (OpenAI-compatible) — mejora mucho la precisión en lenguaje libre.
# Si no se define VOICE_LLM_API_KEY, Saya usa solo reglas + memoria local.
# VOICE_LLM_API_KEY=sk-...
# VOICE_LLM_BASE_URL=https://api.openai.com/v1
# VOICE_LLM_MODEL=gpt-4o-mini
# VOICE_LLM_TIMEOUT_MS=12000
